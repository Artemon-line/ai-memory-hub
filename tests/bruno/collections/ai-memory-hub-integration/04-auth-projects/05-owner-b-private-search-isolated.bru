meta {
  name: Owner B cannot see owner A private memory
  type: http
  seq: 34
  tags: [
    auth
    owner
  ]
}

post {
  url: {{base_url}}/memory/search
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{owner_b_token}}
}

body:json {
  {
    "query": "cobalt-private-alpha {{run_id}}",
    "top_k": 100,
    "source": "bruno-auth",
    "tags": ["bruno", "private"]
  }
}

assert {
  res.status: 200
  res.body.status: "ok"
}

tests {
  test("owner b does not see owner a private memory", function() {
    expect(res.status).to.equal(200);
    expect(res.body.status).to.equal("ok");
    const ids = res.body.results.map((item) => item.id);
    expect(ids).to.not.include(bru.getVar("owner_a_private_id"));
  });
}

settings {
  encodeUrl: true
  timeout: 15000
}
