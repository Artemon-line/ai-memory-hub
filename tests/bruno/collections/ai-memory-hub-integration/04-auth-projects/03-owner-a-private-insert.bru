meta {
  name: Owner A private insert
  type: http
  seq: 32
  tags: [
    auth
    owner
  ]
}

post {
  url: {{base_url}}/memory/insert
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{owner_a_token}}
}

body:json {
  {
    "source": "bruno-auth",
    "timestamp": "2026-06-17T00:00:00Z",
    "messages": [
      {
        "role": "user",
        "text": "Bruno private owner A memory {{run_id}} mentions cobalt-private-alpha."
      }
    ],
    "metadata": {
      "summary": "Bruno owner A private auth memory {{run_id}}.",
      "tags": ["bruno", "auth", "private"],
      "run_id": "{{run_id}}",
      "owner_id": "client-supplied-owner"
    }
  }
}

tests {
  test("owner a private insert succeeds", function() {
    expect(res.status).to.equal(200);
    expect(res.body.status).to.equal("ok");
    expect(res.body.id).to.be.a("string");
    bru.setVar("owner_a_private_id", res.body.id);
  });
}

settings {
  encodeUrl: true
  timeout: 15000
}
