meta {
  name: MCP missing bearer is rejected
  type: http
  seq: 31
  tags: [
    auth
    owner
    mcp-auth
  ]
}

post {
  url: {{mcp_url}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json, text/event-stream
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "initialize",
    "params": {
      "protocolVersion": "2025-06-18",
      "capabilities": {},
      "clientInfo": {
        "name": "bruno-auth-missing",
        "version": "0.1.0"
      }
    }
  }
}

tests {
  const { responseHeader } = require("./scripts/mcp.js");

  test("mcp rejects missing bearer token", function() {
    expect(res.status).to.equal(401);
    expect(responseHeader(res.headers, "www-authenticate")).to.contain("Bearer");
  });
}

settings {
  encodeUrl: true
  timeout: 15000
}
