meta {
  name: API ask memory
  type: http
  seq: 12
  tags: [
    smoke
    api
  ]
}

post {
  url: {{base_url}}/memory/ask
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "question": "What did the Bruno API integration memory {{run_id}} confirm?",
    "top_k": 100,
    "source": "bruno-api",
    "tags": ["bruno", "api"]
  }
}

assert {
  res.status: 200
  res.body.status: "ok"
}

tests {
  test("api ask cites inserted memory", function() {
    expect(res.status).to.equal(200);
    expect(res.body.status).to.equal("ok");
    expect(res.body.answer).to.be.a("string");
    expect(res.body.citations).to.be.an("array").that.is.not.empty;
    const citationIds = res.body.citations.map((item) => item.id);
    expect(citationIds).to.include(bru.getVar("api_memory_id"));
  });
}

settings {
  encodeUrl: true
  timeout: 15000
}
