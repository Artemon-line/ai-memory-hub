meta {
  name: API search memory
  type: http
  seq: 11
  tags: [
    smoke
    api
  ]
}

post {
  url: {{base_url}}/memory/search
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "query": "Bruno API integration {{run_id}}",
    "top_k": 100,
    "source": "bruno-api",
    "tags": ["bruno", "api"]
  }
}

assert {
  res.status: 200
  res.body.status: "ok"
}

tests {
  test("api search finds inserted memory", function() {
    expect(res.status).to.equal(200);
    expect(res.body.status).to.equal("ok");
    expect(res.body.results).to.be.an("array").that.is.not.empty;
    const ids = res.body.results.map((item) => item.id);
    expect(ids).to.include(bru.getVar("api_memory_id"));
  });
}

settings {
  encodeUrl: true
  timeout: 15000
}
