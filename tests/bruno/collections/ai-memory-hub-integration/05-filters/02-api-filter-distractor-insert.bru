meta {
  name: API filter distractor insert
  type: http
  seq: 51
  tags: [
    smoke
    api
    filters
  ]
}

post {
  url: {{base_url}}/memory/insert
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "source": "bruno-filter-distractor",
    "timestamp": "2026-06-10T10:00:00Z",
    "messages": [
      {
        "role": "user",
        "text": "Bruno filter smoke {{run_id}} distractor memory contains the cobalt filter key."
      },
      {
        "role": "assistant",
        "text": "The unfiltered distractor answer is cobalt-distractor-{{run_id}}."
      }
    ],
    "metadata": {
      "summary": "Distractor memory for Bruno filter smoke {{run_id}}.",
      "tags": ["bruno", "filters", "distractor"],
      "run_id": "{{run_id}}"
    }
  }
}

tests {
  test("api filter distractor insert succeeds", function() {
    expect(res.status).to.equal(200);
    expect(res.body.status).to.equal("ok");
    expect(res.body.id).to.be.a("string");
  });
  bru.setVar("filter_distractor_id", res.body.id);
}

settings {
  encodeUrl: true
  timeout: 15000
}
