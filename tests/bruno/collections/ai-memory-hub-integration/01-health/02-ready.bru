meta {
  name: Ready
  type: http
  seq: 2
  tags: [
    smoke
    health
  ]
}

get {
  url: {{base_url}}/ready
  body: none
  auth: none
}

tests {
  test("ready returns ok", function() {
    expect(res.status).to.equal(200);
    expect(res.body.status).to.equal("ok");
    expect(res.body.health).to.be.an("object");
  });
}

settings {
  encodeUrl: true
  timeout: 10000
}
