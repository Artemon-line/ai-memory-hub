meta {
  name: MCP insert memory
  type: http
  seq: 23
  tags: [
    smoke
    mcp
  ]
}

post {
  url: {{mcp_url}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json, text/event-stream
  Mcp-Session-Id: {{mcp_session_id}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 4,
    "method": "tools/call",
    "params": {
      "name": "memory_insert",
      "arguments": {
        "conversation_json": {
          "source": "bruno-mcp",
          "timestamp": "2026-06-17T00:00:00Z",
          "messages": [
            {
              "role": "user",
              "content": "Bruno MCP integration memory {{run_id}} validates streamable HTTP."
            },
            {
              "role": "assistant",
              "content": "Bruno MCP integration response {{run_id}} confirms tool calls."
            }
          ],
          "metadata": {
            "summary": "Bruno MCP integration smoke conversation {{run_id}}.",
            "tags": ["bruno", "integration", "mcp"],
            "run_id": "{{run_id}}"
          }
        }
      }
    }
  }
}

tests {
  const { toolPayload } = require("./scripts/mcp.js");

  test("mcp insert succeeds", function() {
    expect(res.status).to.equal(200);
    const payload = toolPayload(res.body);
    expect(payload.status).to.equal("ok");
    expect(payload.id).to.be.a("string");
    expect(payload.embedded_chunks).to.be.greaterThan(0);
    bru.setVar("mcp_memory_id", payload.id);
  });
}

settings {
  encodeUrl: true
  timeout: 15000
}
